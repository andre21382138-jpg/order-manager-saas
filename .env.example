# Supabase (기존 order-manager 프로젝트 재사용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 운영자 식별 (admin 페이지 접근 허용 이메일, 쉼표 구분)
SUPER_ADMIN_EMAILS=ssakwon@kbh.kr

# 앱 URL (auth 콜백 등에서 사용)
NEXT_PUBLIC_APP_URL=http://localhost:3030

# OAuth state 쿠키 서명 키 (32바이트 base64)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_COOKIE_SECRET=
